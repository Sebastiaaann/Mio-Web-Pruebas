
#
# Variables de entorno de referencia (no sensibles)
#

# API externa HOMA (servidor)
API_HOMA_URL=https://apihoma.homa.cl:7200

# Clave para cifrar cookie de sesión BFF (32+ chars recomendado)
COOKIE_SECRET=CAMBIAR_EN_PRODUCCION

# Flags de frontend
#
# VITE_USE_HOMA_BFF: BLOQUEADO en false.
# Los endpoints BFF (api/homa/auth/*.js) no validan el ID token de Firebase
# server-side. NO cambiar a true hasta completar esa validación.
VITE_USE_HOMA_BFF=false
VITE_FLAG_MEDICIONES=true
VITE_FLAG_PLANES=true
VITE_FLAG_CONTROLES=true
